{
  "name": "quietmark",
  "version": "1.0.0",
  "private": false,
  "description": "A calm macOS Markdown editor with live preview, file sidebar, and outline navigation.",
  "main": "main/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm:dev:electron\"",
    "dev:electron": "wait-on http://127.0.0.1:5173 && QUIETMARK_DEV=1 electron .",
    "build": "vite build && node scripts/copy-main.cjs",
    "package:mac": "node scripts/package-mac.cjs",
    "preview": "vite preview",
    "start": "electron ."
  },
  "keywords": [
    "electron",
    "markdown",
    "macos"
  ],
  "author": "cuixu",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "vditor": "^3.11.2",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3"
  }
}
